<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <TextView
        android:id="@+id/tvSplashTitle"
        android:layout_width="337dp"
        android:layout_height="101dp"
        android:gravity="center"
        android:lineSpacingExtra="20sp"
        android:text="@string/appName"
        android:textColor="@color/black"
        android:textColorHighlight="@color/black"
        android:textSize="45sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/ivCart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.528" />

    <ImageView
        android:id="@+id/ivHeadphone"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/headphone1"
        app:layout_constraintBottom_toBottomOf="@id/ivCart"
        app:layout_constraintEnd_toEndOf="@id/ivCart"
        app:layout_constraintHorizontal_bias="0.3"
        app:layout_constraintStart_toStartOf="@id/ivCart"
        app:layout_constraintTop_toTopOf="@id/ivCart"
        app:layout_constraintVertical_bias="0.2" />

    <ImageView
        android:id="@+id/ivExtraItem"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/wire1"
        app:layout_constraintBottom_toBottomOf="@id/ivCart"
        app:layout_constraintEnd_toEndOf="@id/ivCart"
        app:layout_constraintHorizontal_bias="0.7"
        app:layout_constraintStart_toStartOf="@id/ivCart"
        app:layout_constraintTop_toTopOf="@id/ivCart"
        app:layout_constraintVertical_bias="0.4" />
    <ImageView
        android:id="@+id/ivheadset"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/wire1"
        app:layout_constraintBottom_toBottomOf="@id/ivCart"
        app:layout_constraintEnd_toEndOf="@id/ivCart"
        app:layout_constraintHorizontal_bias="0.7"
        app:layout_constraintStart_toStartOf="@id/ivCart"
        app:layout_constraintTop_toTopOf="@id/ivCart"
        app:layout_constraintVertical_bias="0.4" />
    <ImageView
        android:id="@+id/ivmeow"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/charger"
        app:layout_constraintBottom_toBottomOf="@id/ivCart"
        app:layout_constraintEnd_toEndOf="@id/ivCart"
        app:layout_constraintHorizontal_bias="0.7"
        app:layout_constraintStart_toStartOf="@id/ivCart"
        app:layout_constraintTop_toTopOf="@id/ivCart"
        app:layout_constraintVertical_bias="0.4" />

    <ImageView
        android:id="@+id/ivWatch"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/watch"
        app:layout_constraintBottom_toBottomOf="@id/ivCart"
        app:layout_constraintEnd_toEndOf="@id/ivCart"
        app:layout_constraintHorizontal_bias="0.7"
        app:layout_constraintStart_toStartOf="@id/ivCart"
        app:layout_constraintTop_toTopOf="@id/ivCart"
        app:layout_constraintVertical_bias="0.4" />

    <ImageView
        android:id="@+id/ivhf"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/hf"
        app:layout_constraintBottom_toBottomOf="@id/ivCart"
        app:layout_constraintEnd_toEndOf="@id/ivCart"
        app:layout_constraintHorizontal_bias="0.7"
        app:layout_constraintStart_toStartOf="@id/ivCart"
        app:layout_constraintTop_toTopOf="@id/ivCart"
        app:layout_constraintVertical_bias="0.4" />

    <ImageView
        android:id="@+id/ivCart"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/cart2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.502"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.676" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/Welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hello Dude!"
            android:textColor="@color/black"
            android:textSize="50sp"
            android:textStyle="bold|italic"
            android:fontFamily="cursive" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>